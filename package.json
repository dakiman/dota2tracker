{
  "name": "friendtracker-dota2-stats",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "lint": "pnpm --filter \"./packages/*\" build && pnpm -r lint && tsc -p scripts",
    "test": "pnpm --filter \"./packages/*\" build && vitest run",
    "seed": "pnpm tsx scripts/seed.ts",
    "fetch-data": "pnpm tsx scripts/run-job.ts fetch-data",
    "populate-builds": "pnpm tsx scripts/run-job.ts populate-builds",
    "fetch-hero-builds": "pnpm tsx scripts/run-job.ts fetch-hero-builds",
    "fetch-player-builds": "pnpm tsx scripts/run-job.ts fetch-player-builds",
    "request-parses": "pnpm tsx scripts/run-job.ts request-parses",
    "refresh": "pnpm fetch-data && pnpm populate-builds && pnpm fetch-hero-builds && pnpm fetch-player-builds",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@friendtracker/db": "workspace:*",
    "@friendtracker/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.12.5",
    "pg": "^8.20.0",
    "pinia": "^3.0.4",
    "tsx": "^4.19.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.9",
    "vue": "^3.5.13"
  }
}
